# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
.codegraph/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile

# Firebase client config — not a secret (Android API keys here are scoped
# by package name + SHA-1, not confidential), but it's project-specific and
# trivially re-downloadable from Firebase Console, so it doesn't need to
# live in git. Same reasoning as promptfoo/fixtures/ in the backend repo.
/android/app/google-services.json
/android/app/release

# Release signing — the keystore + its passwords. Losing this file means
# losing the ability to ever publish an update to the same Play Store
# listing, but it must never be in git: back it up somewhere outside this
# repo (password manager, encrypted cloud storage) the moment it's created.
/android/key.properties
/android/*.jks
/android/*.keystore
